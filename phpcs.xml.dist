<?xml version="1.0"?>
<ruleset name="Project PSR-12">
    <description>PSR-12 coding standard with PHPUnit snake_case test methods allowed.</description>

    <file>app</file>
    <file>tests</file>

    <rule ref="PSR12"/>

    <!-- PHPUnit test methods use snake_case (test_*_*); allow it in tests/ -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
</ruleset>
